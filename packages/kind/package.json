    "./*": {
      "import": "./lib/*.js",
      "require": "./lib-cjs/*.js"
    }
  },
  "files": [
    "lib",
    "lib-cjs"
  ],
  "devDependencies": {
    "@dreamkit/tsconfig": "workspace:*"
  }
}
